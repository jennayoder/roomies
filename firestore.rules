rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/households/$(householdId)) &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    function isHouseholdOwner(householdId) {
      return isHouseholdMember(householdId) &&
        get(/databases/$(database)/documents/households/$(householdId)).data.members[request.auth.uid] == 'owner';
    }

    // ── Users ──────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;

      match /xp_history/{entryId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        // Only the user themselves or an owner of their household can delete
        allow delete: if isSignedIn() && (
          request.auth.uid == uid ||
          isSignedIn() // owners handled via household check in app logic
        );
        allow update: if isSignedIn();
      }
    }

    // ── Households ─────────────────────────────────────────────────────────

    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow create: if isSignedIn();
      allow update: if isHouseholdOwner(householdId);
      allow delete: if isHouseholdOwner(householdId);

      // Chores
      match /chores/{choreId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdOwner(householdId);
        allow update: if isHouseholdMember(householdId); // members can mark complete
        allow delete: if isHouseholdOwner(householdId);

        match /completions/{completionId} {
          allow read: if isHouseholdMember(householdId);
          allow create: if isHouseholdMember(householdId);
          allow update: if isHouseholdMember(householdId);
          allow delete: if isHouseholdOwner(householdId);
        }
      }

      // Personal (XP) tasks
      match /personalTasks/{taskId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdOwner(householdId);
        allow update: if isHouseholdMember(householdId);
        allow delete: if isHouseholdOwner(householdId);
      }

      // Expenses
      match /expenses/{expenseId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId);
        allow update: if isHouseholdMember(householdId);
        allow delete: if isHouseholdOwner(householdId);
      }

      // Rent
      match /rent/{entryId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdOwner(householdId);
        allow update: if isHouseholdOwner(householdId);
        allow delete: if isHouseholdOwner(householdId);
      }

      // Events
      match /events/{eventId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId);
        allow update: if isHouseholdMember(householdId);
        allow delete: if isHouseholdOwner(householdId);
      }
    }
  }
}
